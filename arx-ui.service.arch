[Unit]
Description=arx-ui Service
After=network.target
Wants=network.target

[Service]
EnvironmentFile=-/etc/conf.d/arx-ui
Environment="XRAY_VMESS_AEAD_FORCED=false"
Type=simple
WorkingDirectory=/usr/lib/arx-ui/
ExecStart=/usr/lib/arx-ui/arx-ui
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
